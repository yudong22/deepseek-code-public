{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "dialog:default",
    "dialog:allow-ask",
    {
      "identifier": "sql:default",
      "allow": [{ "name": "sqlite:deepseek_code.db" }]
    },
    {
      "identifier": "sql:allow-select",
      "allow": [{ "name": "sqlite:deepseek_code.db" }]
    },
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "name": "sqlite:deepseek_code.db" }]
    }
  ]
}
